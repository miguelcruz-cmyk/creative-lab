# ─────────────────────────────────────────────────────────────────────────────
# Creative Lab — environment configuration
#
# Copy this file to `.env` and fill in your own values. Everything here is read
# server-side only (Vite dev middleware locally, Vercel Functions in prod) — no
# secret is ever bundled into the client.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Meta (Facebook/Instagram) — REQUIRED to see any data ─────────────────────
# A Meta Marketing API access token with the `ads_read` scope, and the ad
# account id you want to analyze (with or without the "act_" prefix).
ACCESS_TOKEN=
AD_ACCOUNT_ID=

# ── Optional: other ad platforms ─────────────────────────────────────────────
# Each platform stays disabled in the UI until its credentials are present.
# TikTok
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
# Snapchat
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REFRESH_TOKEN=
SNAPCHAT_AD_ACCOUNT_ID=
# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
REDDIT_AD_ACCOUNT_ID=

# ── Optional: password gate ──────────────────────────────────────────────────
# Leave unset to run the app open (good for local dev / single user). Set a
# value to require a shared password before the app loads (good for a team
# deployment). Changing or removing it invalidates all existing sessions.
APP_PASSWORD=

# ── Optional: durable cache + cron warmer (recommended for production) ────────
# Provision a Redis database (e.g. Vercel Redis / Upstash) and set its URL so
# snapshots persist across deploys/instances. Without it, the app falls back to
# a per-instance in-memory cache. The store auto-detects any of these names.
REDIS_URL=
# KV_URL=
# UPSTASH_REDIS_URL=

# A long random string protecting the cron warmer (/api/cron/sync). Vercel sends
# `Authorization: Bearer $CRON_SECRET` on scheduled invocations.
CRON_SECRET=
